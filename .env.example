HOST=127.0.0.1
PORT=8081
DRIVER=~fastapi
LOG_LEVEL=INFO

# OneBot V11 API 调用超时（秒），大视频上传需要更长时间
ONEBOT_API_TIMEOUT=120

# 必须与 NapCat OneBot V11 的 token 保持一致
ONEBOT_ACCESS_TOKEN=replace_with_napcat_token

# 若填写则覆盖 config/config.yml 中的 api.api_key
SKIAPI_KEY=replace_with_skiapi_key

# 官方接口密钥（按需填写）
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
NEWAPI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
QWEN_API_KEY=
MOONSHOT_API_KEY=
MISTRAL_API_KEY=
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=

# WebUI 管理面板 token（访问 /api/webui/* 需要）
WEBUI_TOKEN=change_me_to_a_random_string
