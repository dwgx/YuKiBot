HOST=127.0.0.1
PORT=8081
DRIVER=~fastapi
LOG_LEVEL=INFO

# OneBot V11 API 调用超时（秒），大视频上传需要更长时间
ONEBOT_API_TIMEOUT=120

# ── NapCat OneBot V11 连接 ──
# 必须与 NapCat 管理面板中配置的 access_token 完全一致
# 安装后请在 NapCat WebUI (默认 http://127.0.0.1:6099/webui) 中添加反向 WebSocket:
#   地址: ws://127.0.0.1:8081/onebot/v11/ws
#   Token: (填写下方的值)
ONEBOT_ACCESS_TOKEN=replace_with_napcat_token

# ── 默认 AI 模型 API Key ──
# 若填写则覆盖 config/config.yml 中的 api.api_key
SKIAPI_KEY=replace_with_skiapi_key

# ── 官方接口密钥（按需填写，只需填你用的那个） ──
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
NEWAPI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
QWEN_API_KEY=
MOONSHOT_API_KEY=
MISTRAL_API_KEY=
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=

# ── WebUI 管理面板 ──
# 访问 /api/webui/* 需要此 token，建议用随机字符串
# 安装脚本会自动生成，也可手动修改
WEBUI_TOKEN=change_me_to_a_random_string

# ── 搜索引擎（可选） ──
# SearXNG 实例地址，留空则使用 DuckDuckGo
# SEARXNG_URL=http://localhost:8888

# ── 图片生成（可选） ──
# 如果使用独立的图片生成 API
# IMAGE_GEN_API_KEY=
# IMAGE_GEN_BASE_URL=

# ── Cookie 相关（可选，也可在 WebUI 中扫码获取） ──
# BILIBILI_SESSDATA=
# BILIBILI_BILI_JCT=
