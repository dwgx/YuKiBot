  preferred_name_patterns: []
  preferred_name_invalid_parts: []
  preferred_name_blocklist: []
  preferred_name_block_patterns: []
  high_risk_confirm_enable_patterns: []
  high_risk_confirm_disable_patterns: []
knowledge_update:
