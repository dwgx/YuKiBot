    max_text_len: 7000
    llm_max_tokens: 1200
  video_resolver:
    enable: true
    download_max_mb: 128
    download_timeout_seconds: 120
    resolve_total_timeout_seconds: 180
    require_audio_for_send: true
    validate_direct_url: true
    cookies_from_browser: auto
    parse_api_enable: false
    parse_api_base: ''
    search_max_duration_seconds: 300
    search_send_max_duration_seconds: 600
    search_analysis_max_duration_seconds: 900
  vision:
    enable: true
    model_supports_image: auto
    route_text_model_to_local: true
    timeout_seconds: 35
    max_tokens: 1200
    temperature: 0.2
search_followup:
