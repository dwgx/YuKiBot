# Python 缓存与虚拟环境
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
.pytest_cache/
*.log

# 本地环境变量
.env
.env.*
!.env.example

# 本地配置（可能包含密钥）
config/config.yml
config/*.local.yml
plugins/config/*.local.yml

# 运行日志与本地状态目录
logs/
storage/logs/
storage/cache/
storage/tmp/
storage/memory/
storage/knowledge/*.db
storage/knowledge/*.db-*
storage/affinity/
storage/emoji/
storage/sticker/
storage/image_templates/
storage/.secret_key
storage/admin_state.json
storage/whitelist_groups.json

# 编辑器与系统文件
.vscode/
.idea/
*.swp
Thumbs.db
Desktop.ini

# WebUI 前端
webui/node_modules/
webui/dist/
webui/.vite/
webui/*.tsbuildinfo
