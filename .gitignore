# Python 缓存与虚拟环境
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/

# 本地环境变量
.env
.env.*
!.env.example

# 运行日志与本地数据
storage/logs/*
!storage/logs/.gitkeep
storage/memory/daily/*
!storage/memory/daily/.gitkeep
storage/memory/vector/*
!storage/memory/vector/.gitkeep

# 编辑器与系统文件
.vscode/
.idea/
*.swp
Thumbs.db
Desktop.ini
