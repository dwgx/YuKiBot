# 强制所有文本文件使用 LF 行尾
* text=auto eol=lf

# Python 文件
*.py text eol=lf
*.pyi text eol=lf

# 配置文件
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# 文档
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Shell 脚本
*.sh text eol=lf
*.bash text eol=lf

# Web 文件
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
