[Unit]
Description=YuKiKo Bot ({{SERVICE_NAME}})
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{SERVICE_USER}}
WorkingDirectory={{WORKDIR}}
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/env bash {{WORKDIR}}/start.sh
Restart=always
RestartSec=3
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
